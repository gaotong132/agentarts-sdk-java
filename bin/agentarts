#!/usr/bin/env bash
# AgentArts CLI launcher.
#
# Runs the toolkit-cli fat jar so you can invoke `agentarts <command>` from
# the shell. Requires the jar to be built first:
#   mvn -pl agentarts-toolkit-cli package -am -DskipTests
#
# Override the jar location with the AGENTARTS_CLI_JAR env var, or drop a
# copy named agentarts-toolkit-cli.jar next to this script.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

JAR=""
for candidate in \
    "${AGENTARTS_CLI_JAR:-}" \
    "$SCRIPT_DIR/agentarts-toolkit-cli.jar" \
    "$SCRIPT_DIR/../agentarts-toolkit-cli/target/agentarts-toolkit-cli-0.1.0-SNAPSHOT-standalone.jar"; do
    if [ -n "$candidate" ] && [ -f "$candidate" ]; then
        JAR="$candidate"
        break
    fi
done

if [ -z "$JAR" ]; then
    echo "agentarts: CLI jar not found." >&2
    echo "Build it first:  mvn -pl agentarts-toolkit-cli package -am -DskipTests" >&2
    echo "Or set AGENTARTS_CLI_JAR to the jar path." >&2
    exit 1
fi

exec java -jar "$JAR" "$@"
