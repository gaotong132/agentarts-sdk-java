# AgentArts 导航 demo 环境变量模板
# 用法：cp .env.example .env，填入你的值，然后 ./run-demo.sh
# .env 已被 .gitignore 忽略，不会提交（含密钥，勿提交）

# ============================================================
# LLM（真实 Agent 场景需要；不填则走脚本驱动模式，无需 LLM）
# ============================================================
# OpenAI 官方
OPENAI_API_KEY=

# 任意 OpenAI 兼容端点（可选）。示例：
#   华为云 MaaS: https://maas.cn-north-4.myhuaweicloud.com/v1
#   DeepSeek:    https://api.deepseek.com/v1
#   本地 Ollama: http://localhost:11434/v1
OPENAI_BASE_URL=
OPENAI_MODEL_NAME=

# ============================================================
# AgentArts 云上 Memory（上云场景需要；不填则用离线 InMemoryLongTermMemory）
# ============================================================
# 数据面 API Key + Space ID（由控制面 createSpace 产出）
AGENTARTS_MEMORY_API_KEY=
AGENTARTS_MEMORY_SPACE_ID=

# 可选：数据面端点（自建/特殊区域时用）
# AGENTARTS_MEMORY_DATA_ENDPOINT=

# ============================================================
# AgentArts 控制面（仅创建 Memory Space 时需要；demo 运行不需要）
# ============================================================
HUAWEICLOUD_SDK_AK=
HUAWEICLOUD_SDK_SK=
HUAWEICLOUD_SDK_REGION=cn-southwest-2
